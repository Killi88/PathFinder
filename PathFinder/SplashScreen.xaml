<Window x:Class="PathFinder.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">

    <Border x:Name="mainBorder"
            Background="{DynamicResource AppBackground}"
            BorderBrush="{DynamicResource AccentBlue}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="48,36"
            MinWidth="420"
            MinHeight="200">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="4"
                              Opacity="0.5"
                              Color="Black"/>
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- App icon -->
            <Image Source="/PathFinder;component/app.ico"
                   Width="64"
                   Height="64"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Title -->
            <TextBlock x:Name="titleText"
                       Text="PathFinder"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource SplashTitleForeground}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>

            <!-- Subtitle -->
            <TextBlock x:Name="subtitleText"
                       Text="XML / JSON Editor &amp; Path Browser"
                       FontSize="12"
                       Foreground="{DynamicResource SplashSubtitleForeground}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- Loading indicator -->
            <ProgressBar x:Name="loadingBar"
                         IsIndeterminate="True"
                         Height="3"
                         Width="200"
                         HorizontalAlignment="Center"
                         Background="{DynamicResource SplashProgressBackground}"
                         Foreground="{DynamicResource AccentBlue}"
                         BorderThickness="0"/>

            <!-- Status text -->
            <TextBlock x:Name="statusText"
                       Text="Loading…"
                       FontSize="11"
                       Foreground="{DynamicResource SplashStatusForeground}"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>
        </StackPanel>
    </Border>
</Window>
