<Window x:Class="PathFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PathFinder"
        xmlns:avalonSearch="clr-namespace:ICSharpCode.AvalonEdit.Search;assembly=ICSharpCode.AvalonEdit"
        Title="PathFinder"
        Icon="/PathFinder;component/app.ico"
        Height="960"
        Width="1600"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        AllowDrop="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

        <Window.InputBindings>
                <KeyBinding Key="T"
                            Modifiers="Ctrl"
                            Command="local:MainWindow.CloseTabCommand"/>
                <KeyBinding Key="F1"
                            Command="local:MainWindow.HelpCommand"/>
                <KeyBinding Key="G"
                            Modifiers="Ctrl"
                            Command="local:MainWindow.GoToLineCommand"/>
                <KeyBinding Key="M"
                            Modifiers="Ctrl+Shift"
                            Command="local:MainWindow.MinifyCommand"/>
                <KeyBinding Key="H"
                            Modifiers="Ctrl"
                            Command="local:MainWindow.ReplaceCommand"/>
                <KeyBinding Key="S"
                            Modifiers="Ctrl+Shift"
                            Command="local:MainWindow.SaveAllCommand"/>
        </Window.InputBindings>

        <Window.CommandBindings>
                <CommandBinding Command="local:MainWindow.CloseTabCommand"
                                Executed="CloseTab_Click"/>
                <CommandBinding Command="local:MainWindow.HelpCommand"
                                Executed="Help_Click"/>
                <CommandBinding Command="local:MainWindow.GoToLineCommand"
                                Executed="GoToLine_Click"/>
                <CommandBinding Command="local:MainWindow.MinifyCommand"
                                Executed="MinifyDocument_Click"/>
                <CommandBinding Command="local:MainWindow.ReplaceCommand"
                                Executed="FindReplace_Click"/>
                <CommandBinding Command="local:MainWindow.SaveAllCommand"
                                Executed="SaveAll_Click"/>
        </Window.CommandBindings>

        <Window.Resources>

                <BooleanToVisibilityConverter x:Key="BoolToVis"/>

                <!-- ── ContextMenu ── -->
                <Style TargetType="ContextMenu">
                        <Setter Property="Background"
                                Value="{DynamicResource ContextMenuBackground}"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource ContextMenuBorder}"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource ContextMenuForeground}"/>
                </Style>

                <!-- ── MenuItem ControlTemplate: submenu item (leaf, no children) ── -->
                <ControlTemplate x:Key="SubmenuItemTemplate"
                                 TargetType="MenuItem">
                        <Border x:Name="templateRoot"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="0,1"
                                SnapsToDevicePixels="True">
                                <Grid>
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0"
                                                          Content="{TemplateBinding Icon}"
                                                          Width="16"
                                                          Height="16"
                                                          Margin="3"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                        <ContentPresenter Grid.Column="1"
                                                          ContentSource="Header"
                                                          Margin="2,3,8,3"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{TemplateBinding InputGestureText}"
                                                   Margin="4,3,12,3"
                                                   Foreground="{DynamicResource MenuGestureForeground}"
                                                   VerticalAlignment="Center"/>
                                </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="{DynamicResource MenuHighlight}"/>
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource MenuHighlightForeground}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource MenuDisabledForeground}"/>
                                </Trigger>
                        </ControlTemplate.Triggers>
                </ControlTemplate>

                <!-- ── MenuItem ControlTemplate: submenu header (has nested popup) ── -->
                <ControlTemplate x:Key="SubmenuHeaderTemplate"
                                 TargetType="MenuItem">
                        <Grid x:Name="templateRoot"
                              Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                                <Border BorderThickness="0"
                                        Padding="0,1">
                                        <Grid>
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="26"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Content="{TemplateBinding Icon}"
                                                                  Width="16"
                                                                  Height="16"
                                                                  Margin="3"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center"/>
                                                <ContentPresenter Grid.Column="1"
                                                                  ContentSource="Header"
                                                                  Margin="2,3,8,3"
                                                                  RecognizesAccessKey="True"
                                                                  VerticalAlignment="Center"
                                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="›"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource MenuForeground}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                        </Grid>
                                </Border>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                                       Placement="Right">
                                        <Border Background="{DynamicResource ContextMenuBackground}"
                                                BorderBrush="{DynamicResource ContextMenuBorder}"
                                                BorderThickness="1"
                                                Padding="0,2">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                                KeyboardNavigation.TabNavigation="Cycle"
                                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Border>
                                </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="{DynamicResource MenuHighlight}"/>
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource MenuHighlightForeground}"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="{DynamicResource MenuHighlight}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource MenuDisabledForeground}"/>
                                </Trigger>
                        </ControlTemplate.Triggers>
                </ControlTemplate>

                <!-- ── MenuItem ControlTemplate: top-level header in Menu bar ── -->
                <ControlTemplate x:Key="TopLevelHeaderTemplate"
                                 TargetType="MenuItem">
                        <Grid x:Name="templateRoot"
                              Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header"
                                                  Margin="8,4"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                                       Placement="Bottom">
                                        <Border Background="{DynamicResource ContextMenuBackground}"
                                                BorderBrush="{DynamicResource ContextMenuBorder}"
                                                BorderThickness="1"
                                                Padding="0,2">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                                                KeyboardNavigation.TabNavigation="Cycle"
                                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Border>
                                </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="{DynamicResource MenuHighlight}"/>
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource MenuHighlightForeground}"/>
                                </Trigger>
                                <Trigger Property="IsSubmenuOpen"
                                         Value="True">
                                        <Setter TargetName="templateRoot"
                                                Property="Background"
                                                Value="{DynamicResource MenuHighlight}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource MenuDisabledForeground}"/>
                                </Trigger>
                        </ControlTemplate.Triggers>
                </ControlTemplate>

                <!-- ── MenuItem (menus + context menus) ── -->
                <Style TargetType="MenuItem">
                        <Setter Property="Background"
                                Value="{DynamicResource MenuItemBackground}"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource MenuForeground}"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Template"
                                Value="{StaticResource SubmenuItemTemplate}"/>
                        <Style.Triggers>
                                <Trigger Property="Role"
                                         Value="TopLevelHeader">
                                        <Setter Property="Template"
                                                Value="{StaticResource TopLevelHeaderTemplate}"/>
                                </Trigger>
                                <Trigger Property="Role"
                                         Value="SubmenuHeader">
                                        <Setter Property="Template"
                                                Value="{StaticResource SubmenuHeaderTemplate}"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── Separator ── -->
                <Style TargetType="Separator">
                        <Setter Property="Background"
                                Value="{DynamicResource SeparatorColor}"/>
                        <Setter Property="Height"
                                Value="1"/>
                        <Setter Property="Margin"
                                Value="4,2"/>
                </Style>

                <!-- ── TextBox ── -->
                <Style TargetType="TextBox">
                        <Setter Property="Background"
                                Value="{DynamicResource InputBackground}"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource InputForeground}"/>
                        <Setter Property="CaretBrush"
                                Value="{DynamicResource CaretBrush}"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource InputBorder}"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="SelectionBrush"
                                Value="{DynamicResource SelectionBrush}"/>
                        <Setter Property="FontFamily"
                                Value="Consolas"/>
                        <Setter Property="FontSize"
                                Value="12"/>
                        <Setter Property="Padding"
                                Value="6"/>
                        <Setter Property="VerticalContentAlignment"
                                Value="Top"/>
                </Style>

                <!-- ── TabControl ── -->
                <Style TargetType="TabControl">
                        <Setter Property="Background"
                                Value="{DynamicResource ResultsBackground}"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource TabBorderBrush}"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Padding"
                                Value="0"/>
                </Style>

                <!-- ── TabItem ── -->
                <Style TargetType="TabItem">
                        <Setter Property="Background"
                                Value="{DynamicResource TabBackground}"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource TabForeground}"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource TabBorderBrush}"/>
                        <Setter Property="BorderThickness"
                                Value="1,1,1,0"/>
                        <Setter Property="Padding"
                                Value="10,4"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        Margin="0,0,2,0">
                                                        <ContentPresenter ContentSource="Header"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected"
                                                                 Value="True">
                                                                <Setter TargetName="border"
                                                                        Property="Background"
                                                                        Value="{DynamicResource TabActiveBackground}"/>
                                                                <Setter TargetName="border"
                                                                        Property="BorderBrush"
                                                                        Value="{DynamicResource AccentBlue}"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource TabActiveForeground}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="border"
                                                                        Property="Background"
                                                                        Value="{DynamicResource ButtonHover}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled"
                                                                 Value="False">
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource TabBorderBrush}"/>
                                                                <Setter Property="Opacity"
                                                                        Value="0.6"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── ListBox ── -->
                <Style TargetType="ListBox">
                        <Setter Property="Background"
                                Value="{DynamicResource ResultsBackground}"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource InputBorder}"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource ResultsForeground}"/>
                </Style>

                <!-- ── ListBoxItem ── -->
                <Style x:Key="DarkListBoxItem"
                       TargetType="ListBoxItem">
                        <Setter Property="Padding"
                                Value="6,4"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource ResultsForeground}"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch"/>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ResultsItemHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ResultsItemSelected}"/>
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource TabActiveForeground}"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── ListViewItem (inherits DarkListBoxItem look) ── -->
                <Style x:Key="DarkListViewItem"
                       TargetType="ListViewItem">
                        <Setter Property="Padding"
                                Value="6,4"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource ResultsForeground}"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        SnapsToDevicePixels="True">
                                                        <GridViewRowPresenter
                                                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ResultsItemHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ResultsItemSelected}"/>
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource TabActiveForeground}"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── GridView column header ── -->
                <Style x:Key="AllPathsColumnHeader"
                       TargetType="GridViewColumnHeader">
                        <Setter Property="Background"
                                Value="{DynamicResource PanelBackground}"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource LabelForeground}"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource SeparatorColor}"/>
                        <Setter Property="BorderThickness"
                                Value="0,0,1,1"/>
                        <Setter Property="Padding"
                                Value="6,4"/>
                        <Setter Property="FontWeight"
                                Value="SemiBold"/>
                        <Setter Property="FontSize"
                                Value="11"/>
                        <Setter Property="HorizontalContentAlignment"
                                Value="Left"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                                <Grid>
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                  VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Thumb x:Name="PART_HeaderGripper"
                                                               HorizontalAlignment="Right"
                                                               Width="4"
                                                               Margin="0,0,-2,0"
                                                               Cursor="SizeWE"
                                                               Background="Transparent">
                                                                <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                                <Border Background="Transparent"
                                                                                        Width="{TemplateBinding Width}"/>
                                                                        </ControlTemplate>
                                                                </Thumb.Template>
                                                        </Thumb>
                                                </Grid>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── Action button (right panel blue) ── -->
                <Style x:Key="ActionButton"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="{DynamicResource ActionButtonBackground}"/>
                        <Setter Property="Foreground"
                                Value="White"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Padding"
                                Value="12,5"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="FontSize"
                                Value="12"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ActionButtonHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ActionButtonPressed}"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── Toolbar button ── -->
                <Style x:Key="ToolbarButton"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="{DynamicResource ButtonBackground}"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource ButtonForeground}"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource ButtonBorder}"/>
                        <Setter Property="Padding"
                                Value="8,4"/>
                        <Setter Property="Margin"
                                Value="1"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource ButtonHover}"/>
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource SeparatorColor}"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource TabBackground}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Background"
                                                Value="Transparent"/>
                                        <Setter Property="BorderBrush"
                                                Value="Transparent"/>
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource ButtonForegroundDisabled}"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── Toolbar toggle button (used by SearchPanel) ── -->
                <Style x:Key="ToolbarToggleButton"
                       TargetType="ToggleButton">
                        <Setter Property="Background"
                                Value="{DynamicResource ButtonBackground}"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource ButtonForeground}"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="BorderBrush"
                                Value="{DynamicResource ButtonBorder}"/>
                        <Setter Property="Padding"
                                Value="8,4"/>
                        <Setter Property="Margin"
                                Value="1"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                                <Setter TargetName="bd"
                                                                        Property="Background"
                                                                        Value="{DynamicResource AccentBlue}"/>
                                                                <Setter Property="Foreground"
                                                                        Value="White"/>
                                                                <Setter TargetName="bd"
                                                                        Property="BorderBrush"
                                                                        Value="{DynamicResource AccentBlue}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="bd"
                                                                        Property="Background"
                                                                        Value="{DynamicResource ButtonHover}"/>
                                                                <Setter TargetName="bd"
                                                                        Property="BorderBrush"
                                                                        Value="{DynamicResource SeparatorColor}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                                <Setter TargetName="bd"
                                                                        Property="Background"
                                                                        Value="{DynamicResource TabBackground}"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── Status bar button (encoding picker) ── -->
                <Style x:Key="StatusBarButton"
                       TargetType="Button">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource StatusBarForeground}"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Padding"
                                Value="6,2"/>
                        <Setter Property="Cursor"
                                Value="Hand"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="2">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource StatusBarButtonHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource StatusBarButtonPressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Opacity"
                                                Value="0.5"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── Scrollbar: page-click repeat button (transparent track area) ── -->
                <Style x:Key="DarkScrollRepeatButton"
                       TargetType="RepeatButton">
                        <Setter Property="OverridesDefaultStyle"
                                Value="True"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Focusable"
                                Value="False"/>
                        <Setter Property="IsTabStop"
                                Value="False"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}"/>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── Scrollbar: draggable thumb ── -->
                <Style x:Key="DarkScrollThumb"
                       TargetType="Thumb">
                        <Setter Property="OverridesDefaultStyle"
                                Value="True"/>
                        <Setter Property="IsTabStop"
                                Value="False"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="tb"
                                                        Background="{DynamicResource ScrollBarThumb}"
                                                        CornerRadius="3"
                                                        Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="tb"
                                                                        Property="Background"
                                                                        Value="{DynamicResource ScrollBarThumbHover}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging"
                                                                 Value="True">
                                                                <Setter TargetName="tb"
                                                                        Property="Background"
                                                                        Value="{DynamicResource ScrollBarThumbHover}"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── Vertical ScrollBar template ── -->
                <ControlTemplate x:Key="VerticalScrollBarTemplate"
                                 TargetType="ScrollBar">
                        <Border Background="{DynamicResource ScrollBarTrack}"
                                Width="10">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource DarkScrollRepeatButton}"
                                                              Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                                <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource DarkScrollRepeatButton}"
                                                              Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                </Track>
                        </Border>
                </ControlTemplate>

                <!-- ── Horizontal ScrollBar template ── -->
                <ControlTemplate x:Key="HorizontalScrollBarTemplate"
                                 TargetType="ScrollBar">
                        <Border Background="{DynamicResource ScrollBarTrack}"
                                Height="10">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource DarkScrollRepeatButton}"
                                                              Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                                <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource DarkScrollRepeatButton}"
                                                              Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                </Track>
                        </Border>
                </ControlTemplate>

                <!-- ── ScrollBar global style ── -->
                <Style TargetType="ScrollBar">
                        <Setter Property="OverridesDefaultStyle"
                                Value="True"/>
                        <Setter Property="Template"
                                Value="{StaticResource VerticalScrollBarTemplate}"/>
                        <Setter Property="Width"
                                Value="10"/>
                        <Setter Property="MinWidth"
                                Value="10"/>
                        <Style.Triggers>
                                <Trigger Property="Orientation"
                                         Value="Horizontal">
                                        <Setter Property="Template"
                                                Value="{StaticResource HorizontalScrollBarTemplate}"/>
                                        <Setter Property="Height"
                                                Value="10"/>
                                        <Setter Property="MinHeight"
                                                Value="10"/>
                                        <Setter Property="Width"
                                                Value="Auto"/>
                                        <Setter Property="MinWidth"
                                                Value="0"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- ── ScrollViewer corner fix ── -->
                <Style TargetType="ScrollViewer">
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="ScrollViewer">
                                                <Grid>
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                                <RowDefinition/>
                                                                <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <ScrollContentPresenter Grid.Column="0"
                                                                                Grid.Row="0"
                                                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                                                Content="{TemplateBinding Content}"
                                                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                                Margin="{TemplateBinding Padding}"/>
                                                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                                                   Grid.Column="1"
                                                                   Grid.Row="0"
                                                                   Value="{TemplateBinding VerticalOffset}"
                                                                   Maximum="{TemplateBinding ScrollableHeight}"
                                                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                                                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                                                   Orientation="Horizontal"
                                                                   Grid.Column="0"
                                                                   Grid.Row="1"
                                                                   Value="{TemplateBinding HorizontalOffset}"
                                                                   Maximum="{TemplateBinding ScrollableWidth}"
                                                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                                                        <Rectangle Grid.Column="1"
                                                                   Grid.Row="1"
                                                                   Fill="{DynamicResource ScrollBarTrack}"/>
                                                </Grid>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

                <!-- ── AvalonEdit SearchPanel theme ── -->
                <Style TargetType="{x:Type avalonSearch:SearchPanel}">
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type avalonSearch:SearchPanel}">
                                                <Border Background="{DynamicResource PanelBackground}"
                                                        BorderBrush="{DynamicResource InputBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="0,4,20,0">
                                                        <StackPanel Orientation="Horizontal"
                                                                    Margin="6,5"
                                                                    VerticalAlignment="Center">

                                                                <TextBox x:Name="PART_searchTextBox"
                                                                         Width="250"
                                                                         Text="{Binding SearchPattern, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Background="{DynamicResource InputBackground}"
                                                                         Foreground="{DynamicResource InputForeground}"
                                                                         CaretBrush="{DynamicResource CaretBrush}"
                                                                         SelectionBrush="{DynamicResource SelectionBrush}"
                                                                         BorderBrush="{DynamicResource InputBorder}"
                                                                         BorderThickness="1"
                                                                         Padding="5,4"
                                                                         VerticalContentAlignment="Center"
                                                                         FontFamily="Consolas"
                                                                         FontSize="13"/>

                                                                <TextBlock x:Name="PART_matchCount"
                                                                           Foreground="{DynamicResource LabelForeground}"
                                                                           FontSize="11"
                                                                           MinWidth="70"
                                                                           TextAlignment="Center"
                                                                           Margin="6,0,0,0"
                                                                           VerticalAlignment="Center"/>

                                                                <Button Style="{StaticResource ToolbarButton}"
                                                                        ToolTip="Find Previous (Shift+F3)"
                                                                        Margin="4,0,0,0"
                                                                        Command="{x:Static avalonSearch:SearchCommands.FindPrevious}">▲</Button>
                                                                <Button Style="{StaticResource ToolbarButton}"
                                                                        ToolTip="Find Next (F3)"
                                                                        Margin="2,0,0,0"
                                                                        Command="{x:Static avalonSearch:SearchCommands.FindNext}">▼</Button>

                                                                <ToggleButton Style="{StaticResource ToolbarToggleButton}"
                                                                              ToolTip="Match Case"
                                                                              Margin="4,0,0,0"
                                                                              IsChecked="{Binding MatchCase, RelativeSource={RelativeSource TemplatedParent}}">Aa</ToggleButton>
                                                                <ToggleButton Style="{StaticResource ToolbarToggleButton}"
                                                                              ToolTip="Whole Words Only"
                                                                              Margin="2,0,0,0"
                                                                              IsChecked="{Binding WholeWords, RelativeSource={RelativeSource TemplatedParent}}">W</ToggleButton>
                                                                <ToggleButton Style="{StaticResource ToolbarToggleButton}"
                                                                              ToolTip="Use Regular Expressions"
                                                                              Margin="2,0,0,0"
                                                                              IsChecked="{Binding UseRegex, RelativeSource={RelativeSource TemplatedParent}}">.*</ToggleButton>

                                                                <Button Style="{StaticResource ToolbarButton}"
                                                                        ToolTip="Close Search Panel (Esc)"
                                                                        Margin="6,0,0,0"
                                                                        Command="{x:Static avalonSearch:SearchCommands.CloseSearchPanel}">✕</Button>

                                                        </StackPanel>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>

        </Window.Resources>

        <DockPanel Background="{DynamicResource AppBackground}"
                   LastChildFill="True">

                <!-- ═══════════════════════  MENU BAR  ═══════════════════════ -->
                <Menu DockPanel.Dock="Top"
                      Background="{DynamicResource MenuBackground}"
                      Foreground="{DynamicResource MenuForeground}"
                      BorderBrush="{DynamicResource SeparatorColor}"
                      BorderThickness="0,0,0,1">
                        <MenuItem Header="_File">
                                <MenuItem Header="_New File"
                                          Click="NewFile_Click"
                                          InputGestureText="Ctrl+N"/>
                                <MenuItem Header="_Open File…"
                                          Click="OpenFile_Click"
                                          InputGestureText="Ctrl+O"/>
                                <MenuItem x:Name="recentFilesMenu"
                                          Header="_Recent Files"/>
                                <Separator/>
                                <MenuItem Header="_Save"
                                          Click="SaveFile_Click"
                                          InputGestureText="Ctrl+S"/>
                                <MenuItem Header="Save _As…"
                                          Click="SaveFileAs_Click"/>
                                <MenuItem Header="Save A_ll"
                                          Click="SaveAll_Click"
                                          InputGestureText="Ctrl+Shift+S"/>
                                <MenuItem Header="_Close Tab"
                                          Click="CloseTab_Click"
                                          InputGestureText="Ctrl+T"/>
                                <Separator/>
                                <MenuItem Header="E_xit"
                                          Click="Exit_Click"/>
                        </MenuItem>
                        <MenuItem Header="_Edit">
                                <MenuItem Header="_Find"
                                          Click="Find_Click"
                                          InputGestureText="Ctrl+F"/>
                                <MenuItem Header="Find &amp; _Replace"
                                          Click="FindReplace_Click"
                                          InputGestureText="Ctrl+H"/>
                                <MenuItem Header="_Go to Line…"
                                          Click="GoToLine_Click"
                                          InputGestureText="Ctrl+G"/>
                        </MenuItem>
                        <MenuItem Header="F_ormat">
                                <MenuItem Header="_Auto Indent"
                                          Click="FormatDocument_Click"
                                          InputGestureText="Ctrl+Shift+F"/>
                                <MenuItem Header="_Minify"
                                          Click="MinifyDocument_Click"
                                          InputGestureText="Ctrl+Shift+M"/>
                                <MenuItem x:Name="wordWrapMenuItem"
                                          Header="_Word Wrap"
                                          Click="ToggleWordWrap_Click"
                                          IsCheckable="True"/>
                        </MenuItem>
                        <MenuItem Header="_Settings">
                                <MenuItem Header="_Export Settings…"
                                          Click="ExportSettings_Click"/>
                                <MenuItem Header="_Import Settings…"
                                          Click="ImportSettings_Click"/>
                                <Separator/>
                                <MenuItem Header="Customize _Colors…"
                                          Click="CustomizeColors_Click"/>
                                <MenuItem Header="DCSA Schema _URLs…"
                                          Click="DcsaSchemaUrls_Click"/>
                        </MenuItem>
                        <MenuItem Header="_Help">
                                <MenuItem Header="_Help"
                                          Click="Help_Click"
                                          InputGestureText="F1"/>
                                <Separator/>
                                <MenuItem Header="Register '_Open with PathFinder' context menu"
                                          Click="RegisterContextMenu_Click"/>
                        </MenuItem>
                </Menu>

                <!-- ═══════════════════════  TOOLBAR  ═══════════════════════ -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource SeparatorColor}"
                        BorderThickness="0,0,0,1"
                        Padding="4,3">
                        <DockPanel LastChildFill="False">
                                <!-- Theme toggle floats to the top right -->
                                <Button x:Name="ThemeToggleButton"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="ThemeToggle_Click"
                                        ToolTip="Switch to Light Mode"
                                        Margin="4,1,1,1">
                                        <TextBlock x:Name="ThemeToggleIcon"
                                                   Text="☀️"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource ButtonForeground}"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="NewFile_Click"
                                        ToolTip="New File (Ctrl+N)">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="📄"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="New"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="OpenFile_Click"
                                        ToolTip="Open File (Ctrl+O)">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="📂"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Open"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="SaveFile_Click"
                                        ToolTip="Save File (Ctrl+S)"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="💾"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Save"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="SaveAll_Click"
                                        ToolTip="Save All (Ctrl+Shift+S)"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="💾"
                                                           FontSize="14"
                                                           Margin="0,0,1,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="💾"
                                                           FontSize="10"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Save All"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Rectangle Width="1"
                                           Fill="{DynamicResource SeparatorColor}"
                                           Margin="6,2"/>
                                <Button Style="{StaticResource ToolbarButton}"
                                        Click="FormatDocument_Click"
                                        ToolTip="Auto Indent (Ctrl+Shift+F)">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⌨"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Auto Indent"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button x:Name="minifyButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="MinifyDocument_Click"
                                        ToolTip="Minify (Ctrl+Shift+M)"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⊟"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Minify"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button x:Name="wordWrapButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="ToggleWordWrap_Click"
                                        ToolTip="Toggle Word Wrap"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="↵"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Word Wrap"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button x:Name="showWhitespaceButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="ToggleShowWhitespace_Click"
                                        ToolTip="Show Whitespace Characters"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="·"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Whitespace"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Rectangle Width="1"
                                           Fill="{DynamicResource SeparatorColor}"
                                           Margin="6,2"/>
                                <Button x:Name="convertFormatButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="ConvertFormat_Click"
                                        ToolTip="Convert XML ↔ JSON"
                                        IsEnabled="False"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⇄"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock x:Name="convertFormatLabel"
                                                           Text="Convert"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button x:Name="convertToYamlButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="ConvertToYaml_Click"
                                        ToolTip="Convert to YAML"
                                        IsEnabled="False"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⇄"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock x:Name="convertToYamlLabel"
                                                           Text="To YAML"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button x:Name="generateSampleXmlButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="GenerateSampleXml_Click"
                                        ToolTip="Generate a sample XML document from this XSD schema"
                                        IsEnabled="False"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⚙"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Sample XML"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button x:Name="generateSampleJsonButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="GenerateSampleJson_Click"
                                        ToolTip="Generate a sample JSON document from this JSON/YAML Schema"
                                        IsEnabled="False"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⚙"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Sample JSON"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Button x:Name="validateXsdButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="ValidateXsd_Click"
                                        ToolTip="Validate XML against an XSD schema"
                                        IsEnabled="False"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="✓"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock x:Name="validateXsdLabel"
                                                           Text="Validate"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Rectangle Width="1"
                                           Fill="{DynamicResource SeparatorColor}"
                                           Margin="6,2"/>
                                <Button x:Name="copyToExcelButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="CopyToExcel_Click"
                                        ToolTip="Copy to Excel (copies syntax-highlighted HTML to clipboard)"
                                        IsEnabled="False"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="📋"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Copy for Excel"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                                <Rectangle Width="1"
                                           Fill="{DynamicResource SeparatorColor}"
                                           Margin="6,2"/>
                                <Button x:Name="sortDcsaButton"
                                        Style="{StaticResource ToolbarButton}"
                                        Click="SortDcsa_Click"
                                        ToolTip="Sort JSON properties by DCSA schema field order"
                                        IsEnabled="False"
                                        Margin="2,0">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="⇅"
                                                           FontSize="14"
                                                           Margin="0,0,5,0"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                                <TextBlock Text="Sort DCSA"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </StackPanel>
                                </Button>
                        </DockPanel>
                </Border>

                <!-- ═══════════════════════  STATUS BAR  ═══════════════════════ -->
                <StatusBar DockPanel.Dock="Bottom"
                           Background="{DynamicResource StatusBarBackground}"
                           Foreground="{DynamicResource StatusBarForeground}">
                        <StatusBarItem>
                                <TextBlock x:Name="statusText"
                                           Text="Ready"/>
                        </StatusBarItem>
                        <StatusBarItem HorizontalAlignment="Right">
                                <TextBlock x:Name="lineColumnLabel"
                                           Text="Ln 1, Col 1"
                                           Margin="0,0,16,0"/>
                        </StatusBarItem>
                        <StatusBarItem HorizontalAlignment="Right">
                                <TextBlock x:Name="fileTypeLabel"
                                           Text=""
                                           Margin="0,0,16,0"
                                           FontWeight="SemiBold"/>
                        </StatusBarItem>
                        <StatusBarItem HorizontalAlignment="Right">
                                <Button x:Name="encodingButton"
                                        Content="UTF-8"
                                        Style="{StaticResource StatusBarButton}"
                                        Click="EncodingButton_Click"
                                        Margin="0,0,8,0"
                                        ToolTip="Click to change file encoding"/>
                        </StatusBarItem>
                        <StatusBarItem HorizontalAlignment="Right">
                                <TextBlock x:Name="filePathLabel"
                                           Text=""
                                           Margin="0,0,8,0"/>
                        </StatusBarItem>
                </StatusBar>

                <!-- ═══════════════════════  MAIN SPLIT  ═══════════════════════ -->
                <Grid>
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"
                                                  MinWidth="300"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition x:Name="rightPanelColumn"
                                                  Width="640"
                                                  MinWidth="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- ─────────────  LEFT: Multi-tab editor  ───────────── -->
                        <Grid Grid.Column="0">
                                <TabControl x:Name="editorTabs"
                                            Background="{DynamicResource EditorBackground}"
                                            BorderBrush="{DynamicResource TabBorderBrush}"
                                            BorderThickness="0,0,1,0"
                                            SelectionChanged="EditorTabs_SelectionChanged"/>
                                <!-- floating buttons at top-right: new tab  |  close active tab -->
                                <StackPanel HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Orientation="Horizontal"
                                            Margin="0,1,4,0"
                                            Panel.ZIndex="10">
                                        <Button x:Name="newTabButton"
                                                Width="28"
                                                Height="26"
                                                Style="{StaticResource ToolbarButton}"
                                                Click="NewFile_Click"
                                                ToolTip="New Tab (Ctrl+N)">
                                                <TextBlock Text="+"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ButtonForeground}"
                                                           Margin="0,-1,0,0"/>
                                        </Button>
                                        <Button x:Name="closeActiveTabButton"
                                                Width="28"
                                                Height="26"
                                                Margin="1,0,0,0"
                                                Style="{StaticResource ToolbarButton}"
                                                Click="CloseTab_Click"
                                                ToolTip="Close Active Tab (Ctrl+T)">
                                                <TextBlock Text="✕"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource ButtonForeground}"/>
                                        </Button>
                                </StackPanel>
                        </Grid>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1"
                                      Width="5"
                                      HorizontalAlignment="Stretch"
                                      Background="{DynamicResource PanelBackground}"
                                      ShowsPreview="True"/>

                        <!-- ─────────────  RIGHT: Tool tabs  ───────────── -->
                        <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TabControl x:Name="rightTabs"
                                            Grid.Row="0"
                                            Background="{DynamicResource ResultsBackground}"
                                            BorderBrush="{DynamicResource TabBorderBrush}">

                                        <!-- ════════  TAB: XPath / JSONPath  ════════ -->
                                        <TabItem x:Name="xpathTab"
                                                 Header="XPath">
                                                <Grid x:Name="xpathContent"
                                                      Margin="10"
                                                      Background="{DynamicResource ResultsBackground}">
                                                        <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="100"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   x:Name="xpathLabel"
                                                                   Text="XPath Expression  (Ctrl+Enter to execute):"
                                                                   Foreground="{DynamicResource LabelForeground}"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,0,4"/>

                                                        <TextBox Grid.Row="1"
                                                                 x:Name="xpathInput"
                                                                 AcceptsReturn="True"
                                                                 AcceptsTab="False"
                                                                 TextWrapping="Wrap"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 ToolTip="Enter an XPath or JSONPath expression and press Ctrl+Enter (or click Execute) to run it. See Help (F1) for usage examples."
                                                                 KeyDown="XpathInput_KeyDown"
                                                                 PreviewKeyDown="XpathInput_PreviewKeyDown"
                                                                 TextChanged="XpathInput_TextChanged"/>
                                                        <Popup x:Name="autocompletePopup"
                                                               PlacementTarget="{Binding ElementName=xpathInput}"
                                                               Placement="Bottom"
                                                               StaysOpen="False"
                                                               AllowsTransparency="True">
                                                                <Border Background="{DynamicResource EditorBackground}"
                                                                        BorderBrush="{DynamicResource GridSplitterColor}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="3"
                                                                        MaxHeight="200"
                                                                        Width="{Binding ActualWidth, ElementName=xpathInput}">
                                                                        <ListBox x:Name="autocompleteList"
                                                                                 Background="{DynamicResource EditorBackground}"
                                                                                 Foreground="{DynamicResource EditorForeground}"
                                                                                 BorderThickness="0"
                                                                                 FontFamily="Consolas"
                                                                                 FontSize="11"
                                                                                 SelectionChanged="AutocompleteList_SelectionChanged"
                                                                                 MouseDoubleClick="AutocompleteList_MouseDoubleClick"/>
                                                                </Border>
                                                        </Popup>

                                                        <Button Grid.Row="2"
                                                                x:Name="executeXpathBtn"
                                                                Content="▶  Execute XPath"
                                                                Style="{StaticResource ActionButton}"
                                                                Click="ExecuteXPath_Click"
                                                                HorizontalAlignment="Left"
                                                                Margin="0,8,0,8"
                                                                ToolTip="Execute the expression above (Ctrl+Enter). See Help (F1) for usage examples and syntax reference."/>

                                                        <TextBlock Grid.Row="3"
                                                                   x:Name="xpathResultsHeader"
                                                                   Text="Results:"
                                                                   Foreground="{DynamicResource LabelForeground}"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,0,4"/>

                                                        <ListBox Grid.Row="4"
                                                                 x:Name="xpathResultsList"
                                                                 FontSize="11"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                 SelectionChanged="XpathResult_SelectionChanged"
                                                                 Cursor="Hand"
                                                                 ToolTip="Click a result to navigate to it in the editor"
                                                                 ItemContainerStyle="{StaticResource DarkListBoxItem}">
                                                                <ListBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                                <StackPanel Margin="2,1">
                                                                                        <TextBlock Text="{Binding XPath}"
                                                                                                   Foreground="{DynamicResource AllPathsPathColor}"
                                                                                                   FontFamily="Consolas"
                                                                                                   FontWeight="SemiBold"
                                                                                                   TextWrapping="Wrap"/>
                                                                                        <TextBlock Text="{Binding Preview}"
                                                                                                   Foreground="{DynamicResource AllPathsValueColor}"
                                                                                                   FontFamily="Consolas"
                                                                                                   Margin="8,1,0,0"
                                                                                                   TextWrapping="Wrap"
                                                                                                   Opacity="0.85"/>
                                                                                        <TextBlock Text="{Binding LineNumber, StringFormat='Line {0}'}"
                                                                                                   Foreground="{DynamicResource ResultsLineNumber}"
                                                                                                   Margin="8,1,0,0"/>
                                                                                </StackPanel>
                                                                        </DataTemplate>
                                                                </ListBox.ItemTemplate>
                                                        </ListBox>
                                                </Grid>
                                        </TabItem>

                                        <!-- ════════  TAB: All Paths  ════════ -->
                                        <TabItem x:Name="allPathsTab"
                                                 Header="All Paths">
                                                <Grid Background="{DynamicResource ResultsBackground}">
                                                        <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                Padding="10,8,10,6"
                                                                BorderBrush="{DynamicResource SeparatorColor}"
                                                                BorderThickness="0,0,0,1">
                                                                <TextBlock x:Name="allPathsHeader"
                                                                           Text="All Paths"
                                                                           Foreground="{DynamicResource LabelForeground}"
                                                                           FontWeight="SemiBold"/>
                                                        </Border>

                                                        <Border Grid.Row="1"
                                                                Padding="8,6"
                                                                BorderBrush="{DynamicResource SeparatorColor}"
                                                                BorderThickness="0,0,0,1">
                                                                <Grid>
                                                                        <TextBox x:Name="allPathsFilter"
                                                                                 TextChanged="AllPathsFilter_TextChanged"
                                                                                 FontFamily="Consolas"
                                                                                 FontSize="12"
                                                                                 Padding="5,4,22,4"
                                                                                 ToolTip="Filter by path or value (case-insensitive)"/>
                                                                        <TextBlock x:Name="allPathsFilterHint"
                                                                                   Text="Filter paths or values…"
                                                                                   IsHitTestVisible="False"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="7,0,0,0"
                                                                                   Foreground="{DynamicResource PlaceholderForeground}"
                                                                                   FontFamily="Consolas"
                                                                                   FontSize="12"/>
                                                                        <Button x:Name="allPathsFilterClear"
                                                                                Click="AllPathsFilterClear_Click"
                                                                                Content="✕"
                                                                                Visibility="Collapsed"
                                                                                HorizontalAlignment="Right"
                                                                                VerticalAlignment="Center"
                                                                                Width="18"
                                                                                Height="18"
                                                                                Margin="0,0,3,0"
                                                                                Padding="0"
                                                                                FontSize="10"
                                                                                Foreground="{DynamicResource PlaceholderForeground}"
                                                                                Background="Transparent"
                                                                                BorderThickness="0"
                                                                                Cursor="Arrow"
                                                                                ToolTip="Clear filter"/>
                                                                </Grid>
                                                        </Border>

                                                        <ListView Grid.Row="2"
                                                                  x:Name="allPathsList"
                                                                  FontSize="11"
                                                                  BorderThickness="0"
                                                                  Background="{DynamicResource ResultsBackground}"
                                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                  SelectionChanged="AllPaths_SelectionChanged"
                                                                  Cursor="Hand"
                                                                  ToolTip="Click a row to navigate; use ⎘ to copy the path"
                                                                  ItemContainerStyle="{StaticResource DarkListViewItem}">
                                                                <ListView.View>
                                                                        <GridView ColumnHeaderContainerStyle="{StaticResource AllPathsColumnHeader}">
                                                                                <GridViewColumn Header="Path"
                                                                                                Width="250">
                                                                                        <GridViewColumn.CellTemplate>
                                                                                                <DataTemplate>
                                                                                                        <TextBlock Text="{Binding XPath}"
                                                                                                                   Foreground="{DynamicResource AllPathsPathColor}"
                                                                                                                   FontFamily="Consolas"
                                                                                                                   TextTrimming="CharacterEllipsis"
                                                                                                                   ToolTip="{Binding XPath}"/>
                                                                                                </DataTemplate>
                                                                                        </GridViewColumn.CellTemplate>
                                                                                </GridViewColumn>
                                                                                <GridViewColumn Header="Value"
                                                                                                Width="150">
                                                                                        <GridViewColumn.CellTemplate>
                                                                                                <DataTemplate>
                                                                                                        <TextBlock Text="{Binding Preview}"
                                                                                                                   Foreground="{DynamicResource AllPathsValueColor}"
                                                                                                                   FontFamily="Consolas"
                                                                                                                   TextTrimming="CharacterEllipsis"
                                                                                                                   ToolTip="{Binding Preview}"/>
                                                                                                </DataTemplate>
                                                                                        </GridViewColumn.CellTemplate>
                                                                                </GridViewColumn>
                                                                                <GridViewColumn Width="50">
                                                                                        <GridViewColumn.CellTemplate>
                                                                                                <DataTemplate>
                                                                                                        <Button Tag="{Binding XPath}"
                                                                                                                Click="AllPathsCopyItem_Click"
                                                                                                                Content="⎘"
                                                                                                                ToolTip="Copy path to clipboard"
                                                                                                                Padding="4,1"
                                                                                                                Margin="0"
                                                                                                                VerticalAlignment="Center"
                                                                                                                Style="{StaticResource ToolbarButton}"/>
                                                                                                </DataTemplate>
                                                                                        </GridViewColumn.CellTemplate>
                                                                                </GridViewColumn>
                                                                        </GridView>
                                                                </ListView.View>
                                                        </ListView>
                                                </Grid>
                                        </TabItem>

                                        <!-- ════════  TAB: Messages  ════════ -->
                                        <TabItem x:Name="messagesTab"
                                                 Header="Messages">
                                                <Grid Background="{DynamicResource ResultsBackground}">
                                                        <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                Padding="10,8,10,6"
                                                                BorderBrush="{DynamicResource SeparatorColor}"
                                                                BorderThickness="0,0,0,1">
                                                                <TextBlock x:Name="messagesHeader"
                                                                           Text="Messages"
                                                                           Foreground="{DynamicResource LabelForeground}"
                                                                           FontWeight="SemiBold"/>
                                                        </Border>

                                                        <ListBox Grid.Row="1"
                                                                 x:Name="messagesList"
                                                                 FontSize="11"
                                                                 BorderThickness="0"
                                                                 Background="{DynamicResource ResultsBackground}"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                 SelectionMode="Extended"
                                                                 SelectionChanged="MessagesList_SelectionChanged"
                                                                 Cursor="Hand"
                                                                 ToolTip="Click a message to navigate to the line in the editor"
                                                                 ItemContainerStyle="{StaticResource DarkListBoxItem}">
                                                                <ListBox.InputBindings>
                                                                        <KeyBinding Key="C"
                                                                                    Modifiers="Ctrl"
                                                                                    Command="{x:Static ApplicationCommands.Copy}"/>
                                                                </ListBox.InputBindings>
                                                                <ListBox.CommandBindings>
                                                                        <CommandBinding Command="{x:Static ApplicationCommands.Copy}"
                                                                                        Executed="MessagesList_Copy"/>
                                                                </ListBox.CommandBindings>
                                                                <ListBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                                <StackPanel>
                                                                                        <TextBlock Text="{Binding Display}"
                                                                                                   FontFamily="Consolas"
                                                                                                   TextWrapping="Wrap"
                                                                                                   Margin="2,1">
                                                                                                <TextBlock.Style>
                                                                                                        <Style TargetType="TextBlock">
                                                                                                                <Setter Property="Foreground"
                                                                                                                        Value="{DynamicResource MessagesErrorColor}"/>
                                                                                                                <Style.Triggers>
                                                                                                                        <DataTrigger Binding="{Binding IsSuccess}"
                                                                                                                                     Value="True">
                                                                                                                                <Setter Property="Foreground"
                                                                                                                                        Value="{DynamicResource MessagesSuccessColor}"/>
                                                                                                                        </DataTrigger>
                                                                                                                </Style.Triggers>
                                                                                                        </Style>
                                                                                                </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                        <TextBlock Margin="2,0,2,2"
                                                                                                   Visibility="{Binding HasCodeList, Converter={StaticResource BoolToVis}}">
                                                                                                <Hyperlink Click="ViewCodeList_Click"
                                                                                                           Foreground="{DynamicResource AccentBlue}"
                                                                                                           TextDecorations="None"
                                                                                                           FontFamily="Consolas"
                                                                                                           FontSize="11">
                                                                                                        📋 Show valid codes
                                                                                                </Hyperlink>
                                                                                        </TextBlock>
                                                                                </StackPanel>
                                                                        </DataTemplate>
                                                                </ListBox.ItemTemplate>
                                                        </ListBox>
                                                </Grid>
                                        </TabItem>

                                </TabControl>
                                <Border Grid.Row="1"
                                        BorderThickness="0,1,0,0"
                                        Padding="2,1"
                                        Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource SeparatorColor}">
                                        <DockPanel LastChildFill="False">
                                                <StackPanel DockPanel.Dock="Right"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                        <Button x:Name="rightPanelZoomOutBtn"
                                                                Click="RightPanelZoomOut_Click"
                                                                Content="−"
                                                                Style="{StaticResource ToolbarButton}"
                                                                Padding="4,1"
                                                                Width="22"
                                                                Height="18"
                                                                ToolTip="Zoom out (Ctrl+Scroll)"/>
                                                        <TextBlock x:Name="rightPanelZoomLabel"
                                                                   Text="100%"
                                                                   Width="36"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource ButtonForeground}"
                                                                   Cursor="Hand"
                                                                   ToolTip="Click to reset zoom"/>
                                                        <Button x:Name="rightPanelZoomInBtn"
                                                                Click="RightPanelZoomIn_Click"
                                                                Content="+"
                                                                Style="{StaticResource ToolbarButton}"
                                                                Padding="4,1"
                                                                Width="22"
                                                                Height="18"
                                                                ToolTip="Zoom in (Ctrl+Scroll)"/>
                                                </StackPanel>
                                        </DockPanel>
                                </Border>
                        </Grid>
                </Grid>
        </DockPanel>
</Window>
