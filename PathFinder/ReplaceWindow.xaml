<Window x:Class="PathFinder.ReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find and Replace"
        Width="440"
        SizeToContent="Height"
        MinWidth="380"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource AppBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Find row -->
        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Find:"
                   VerticalAlignment="Center"
                   Margin="0,0,8,6"
                   Foreground="{DynamicResource LabelForeground}"/>
        <TextBox x:Name="findBox"
                 Grid.Row="0"
                 Grid.Column="1"
                 Margin="0,0,6,6"
                 Padding="3,2"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="{DynamicResource EditorBackground}"
                 Foreground="{DynamicResource EditorForeground}"
                 TextChanged="FindBox_TextChanged"/>
        <StackPanel Grid.Row="0"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,6">
            <Button x:Name="findPrevButton"
                    Content="▲"
                    Width="28"
                    Height="26"
                    IsTabStop="False"
                    Click="FindPrev_Click"
                    ToolTip="Find Previous"
                    Style="{DynamicResource ReplaceActionButton}"/>
            <Button x:Name="findNextButton"
                    Content="▼"
                    Width="28"
                    Height="26"
                    IsTabStop="False"
                    Click="FindNext_Click"
                    ToolTip="Find Next"
                    Margin="2,0,0,0"
                    Style="{DynamicResource ReplaceActionButton}"/>
        </StackPanel>

        <!-- Replace row -->
        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Text="Replace:"
                   VerticalAlignment="Center"
                   Margin="0,0,8,6"
                   Foreground="{DynamicResource LabelForeground}"/>
        <TextBox x:Name="replaceBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,0,6,6"
                 Padding="3,2"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="{DynamicResource EditorBackground}"
                 Foreground="{DynamicResource EditorForeground}"/>
        <StackPanel Grid.Row="1"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,6">
            <Button x:Name="replaceButton"
                    Content="Replace"
                    Height="26"
                    IsTabStop="False"
                    Click="Replace_Click"
                    Padding="8,0"
                    Style="{DynamicResource ReplaceActionButton}"/>
            <Button x:Name="replaceAllButton"
                    Content="Replace All"
                    Height="26"
                    IsTabStop="False"
                    Click="ReplaceAll_Click"
                    Padding="8,0"
                    Margin="2,0,0,0"
                    Style="{DynamicResource ReplaceActionButton}"/>
        </StackPanel>

        <!-- Options row -->
        <StackPanel Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    Margin="0,2,0,6">
            <CheckBox x:Name="matchCaseCheck"
                      Content="Match _case"
                      Margin="0,0,12,0"
                      Foreground="{DynamicResource EditorForeground}"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed"/>
            <CheckBox x:Name="wholeWordsCheck"
                      Content="Whole _words"
                      Margin="0,0,12,0"
                      Foreground="{DynamicResource EditorForeground}"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed"/>
            <CheckBox x:Name="useRegexCheck"
                      Content="Use rege_x"
                      Foreground="{DynamicResource EditorForeground}"
                      Checked="Option_Changed"
                      Unchecked="Option_Changed"/>
            <CheckBox x:Name="allDocsCheck"
                      Content="All _documents"
                      Margin="12,0,0,0"
                      Foreground="{DynamicResource EditorForeground}"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock x:Name="statusLabel"
                   Grid.Row="3"
                   Grid.Column="0"
                   Grid.ColumnSpan="3"
                   Text=""
                   Foreground="{DynamicResource LabelForeground}"
                   Margin="0,0,0,0"
                   FontSize="11"/>
    </Grid>

    <Window.Resources>
        <Style x:Key="ReplaceActionButton"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{DynamicResource ActionButtonBackground}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource StatusBarButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
