<Window x:Class="PathFinder.SyntaxColorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customize Syntax Colors"
        Width="500"
        Height="880"
        MinWidth="440"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource AppBackground}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Theme toggle -->
        <Border Grid.Row="0"
                Padding="16,12,16,8"
                BorderBrush="{DynamicResource GridSplitterColor}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Editing colors for:"
                           Foreground="{DynamicResource LabelForeground}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           FontSize="12"/>
                <RadioButton x:Name="darkRadio"
                             Content=" Dark Theme"
                             Foreground="{DynamicResource EditorForeground}"
                             VerticalAlignment="Center"
                             IsChecked="True"
                             Margin="0,0,16,0"
                             Checked="ThemeRadio_Checked"/>
                <RadioButton x:Name="lightRadio"
                             Content=" Light Theme"
                             Foreground="{DynamicResource EditorForeground}"
                             VerticalAlignment="Center"
                             Checked="ThemeRadio_Checked"/>
            </StackPanel>
        </Border>

        <!-- Color entries (built in code-behind) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0">
            <StackPanel x:Name="colorPanel"
                        Margin="16,8,16,8"/>
        </ScrollViewer>

        <!-- Button bar -->
        <Border Grid.Row="2"
                Padding="16,10"
                BorderBrush="{DynamicResource GridSplitterColor}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Button x:Name="resetButton"
                        Content="Reset to Defaults"
                        HorizontalAlignment="Left"
                        Click="ResetDefaults_Click"
                        Padding="12,5"
                        Cursor="Hand"
                        Background="{DynamicResource ActionButtonBackground}"
                        Foreground="White"
                        BorderThickness="0"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Apply"
                            Click="Apply_Click"
                            Padding="20,5"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Background="{DynamicResource ActionButtonBackground}"
                            Foreground="White"
                            BorderThickness="0"/>
                    <Button Content="OK"
                            Click="OK_Click"
                            IsDefault="True"
                            Padding="20,5"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Background="{DynamicResource AccentBlue}"
                            Foreground="White"
                            BorderThickness="0"/>
                    <Button Content="Cancel"
                            Click="Cancel_Click"
                            IsCancel="True"
                            Padding="20,5"
                            Cursor="Hand"
                            Background="{DynamicResource ActionButtonBackground}"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
