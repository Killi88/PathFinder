<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Main window background -->
    <SolidColorBrush x:Key="AppBackground"
                     Color="#F5F5F5"/>

    <!-- Toolbar, side panel background -->
    <SolidColorBrush x:Key="PanelBackground"
                     Color="#EAEAEA"/>

    <!-- AvalonEdit editor background -->
    <SolidColorBrush x:Key="EditorBackground"
                     Color="#FFFFFF"/>

    <!-- AvalonEdit editor text color -->
    <SolidColorBrush x:Key="EditorForeground"
                     Color="#1E1E1E"/>

    <!-- Inactive tab background -->
    <SolidColorBrush x:Key="TabBackground"
                     Color="#EAEAEA"/>

    <!-- Active/selected tab background -->
    <SolidColorBrush x:Key="TabActiveBackground"
                     Color="#FFFFFF"/>

    <!-- Tab text color -->
    <SolidColorBrush x:Key="TabForeground"
                     Color="#555555"/>

    <!-- Active tab text color -->
    <SolidColorBrush x:Key="TabActiveForeground"
                     Color="#1E1E1E"/>

    <!-- Tab border color -->
    <SolidColorBrush x:Key="TabBorderBrush"
                     Color="#C8C8C8"/>

    <!-- Menu bar background -->
    <SolidColorBrush x:Key="MenuBackground"
                     Color="#F0F0F0"/>

    <!-- Menu bar text -->
    <SolidColorBrush x:Key="MenuForeground"
                     Color="#1E1E1E"/>

    <!-- Menu item background -->
    <SolidColorBrush x:Key="MenuItemBackground"
                     Color="#F0F0F0"/>

    <!-- Menu item hover background -->
    <SolidColorBrush x:Key="MenuItemHover"
                     Color="#DDE4F0"/>

    <!-- Context menu background -->
    <SolidColorBrush x:Key="ContextMenuBackground"
                     Color="#F5F5F5"/>

    <!-- Context menu border -->
    <SolidColorBrush x:Key="ContextMenuBorder"
                     Color="#C0C0C0"/>

    <!-- Context menu text -->
    <SolidColorBrush x:Key="ContextMenuForeground"
                     Color="#1E1E1E"/>

    <!-- Toolbar button background -->
    <SolidColorBrush x:Key="ButtonBackground"
                     Color="Transparent"/>

    <!-- Toolbar button text/icon color -->
    <SolidColorBrush x:Key="ButtonForeground"
                     Color="#333333"/>

    <!-- Toolbar button hover background -->
    <SolidColorBrush x:Key="ButtonHover"
                     Color="#DDE4F0"/>

    <!-- Toolbar button border -->
    <SolidColorBrush x:Key="ButtonBorder"
                     Color="Transparent"/>

    <!-- Toolbar button text/icon color when disabled -->
    <SolidColorBrush x:Key="ButtonForegroundDisabled"
                     Color="#AAAAAA"/>

    <!-- Text boxes, XPath input background -->
    <SolidColorBrush x:Key="InputBackground"
                     Color="#FFFFFF"/>

    <!-- Text boxes text color -->
    <SolidColorBrush x:Key="InputForeground"
                     Color="#1E1E1E"/>

    <!-- Text boxes border -->
    <SolidColorBrush x:Key="InputBorder"
                     Color="#BBBBBB"/>

    <!-- Divider lines -->
    <SolidColorBrush x:Key="SeparatorColor"
                     Color="#C8C8C8"/>

    <!-- Scrollbar background track -->
    <SolidColorBrush x:Key="ScrollBarTrack"
                     Color="#EAEAEA"/>

    <!-- Scrollbar thumb color -->
    <SolidColorBrush x:Key="ScrollBarThumb"
                     Color="#BBBBBB"/>

    <!-- Scrollbar thumb hover color -->
    <SolidColorBrush x:Key="ScrollBarThumbHover"
                     Color="#888888"/>

    <!-- XPath results list background -->
    <SolidColorBrush x:Key="ResultsBackground"
                     Color="#F0F0F0"/>

    <!-- XPath results item hover -->
    <SolidColorBrush x:Key="ResultsItemHover"
                     Color="#E8EDF5"/>

    <!-- XPath results item selected -->
    <SolidColorBrush x:Key="ResultsItemSelected"
                     Color="#CCE4F8"/>

    <!-- XPath results text color -->
    <SolidColorBrush x:Key="ResultsForeground"
                     Color="#1E1E1E"/>

    <!-- XPath results secondary/preview text -->
    <SolidColorBrush x:Key="ResultsSecondary"
                     Color="#666666"/>

    <!-- Status bar background -->
    <SolidColorBrush x:Key="StatusBarBackground"
                     Color="#007ACC"/>

    <!-- Status bar text -->
    <SolidColorBrush x:Key="StatusBarForeground"
                     Color="#FFFFFF"/>

    <!-- Grid/tree view background -->
    <SolidColorBrush x:Key="GridViewBackground"
                     Color="#FFFFFF"/>

    <!-- Grid/tree view text -->
    <SolidColorBrush x:Key="GridViewForeground"
                     Color="#1E1E1E"/>

    <!-- Section label text (e.g. "XPath Expression", "Results:") -->
    <SolidColorBrush x:Key="LabelForeground"
                     Color="#005B9E"/>

    <!-- Tree item hover background -->
    <SolidColorBrush x:Key="TreeItemHover"
                     Color="#E8EDF5"/>

    <!-- Tree item selected background -->
    <SolidColorBrush x:Key="TreeItemSelected"
                     Color="#CCE4F8"/>

    <!-- All Paths panel: path column color -->
    <SolidColorBrush x:Key="AllPathsPathColor"
                     Color="#0D62B5"/>

    <!-- All Paths panel: value column color -->
    <SolidColorBrush x:Key="AllPathsValueColor"
                     Color="#A84300"/>

    <!-- Messages panel: error text color -->
    <SolidColorBrush x:Key="MessagesErrorColor"
                     Color="#C72E2E"/>
    <SolidColorBrush x:Key="MessagesSuccessColor"
                     Color="#1A7070"/>

    <!-- Menu item highlight background -->
    <SolidColorBrush x:Key="MenuHighlight"
                     Color="#C9DEF5"/>

    <!-- Menu item highlight text -->
    <SolidColorBrush x:Key="MenuHighlightForeground"
                     Color="#1E1E1E"/>

    <!-- Menu item disabled text -->
    <SolidColorBrush x:Key="MenuDisabledForeground"
                     Color="#AAAAAA"/>

    <!-- Menu keyboard shortcut text -->
    <SolidColorBrush x:Key="MenuGestureForeground"
                     Color="#999999"/>

    <!-- Text input caret color -->
    <SolidColorBrush x:Key="CaretBrush"
                     Color="#1E1E1E"/>

    <!-- Text input selection highlight -->
    <SolidColorBrush x:Key="SelectionBrush"
                     Color="#ADD6FF"/>

    <!-- Results list line number text -->
    <SolidColorBrush x:Key="ResultsLineNumber"
                     Color="#999999"/>

    <!-- Placeholder / hint text -->
    <SolidColorBrush x:Key="PlaceholderForeground"
                     Color="#999999"/>

    <!-- Accent blue (active tab border, toggle checked) -->
    <SolidColorBrush x:Key="AccentBlue"
                     Color="#007ACC"/>

    <!-- Action button (Execute) background -->
    <SolidColorBrush x:Key="ActionButtonBackground"
                     Color="#0E639C"/>

    <!-- Action button hover -->
    <SolidColorBrush x:Key="ActionButtonHover"
                     Color="#1177BB"/>

    <!-- Action button pressed -->
    <SolidColorBrush x:Key="ActionButtonPressed"
                     Color="#0A4F7A"/>

    <!-- Action button disabled -->
    <SolidColorBrush x:Key="ActionButtonDisabled"
                     Color="#B0B0B0"/>
    <SolidColorBrush x:Key="ActionButtonDisabledForeground"
                     Color="#808080"/>

    <!-- Status bar button hover overlay -->
    <SolidColorBrush x:Key="StatusBarButtonHover"
                     Color="#20FFFFFF"/>

    <!-- Status bar button pressed overlay -->
    <SolidColorBrush x:Key="StatusBarButtonPressed"
                     Color="#38FFFFFF"/>

    <!-- Splash screen title text -->
    <SolidColorBrush x:Key="SplashTitleForeground"
                     Color="#111111"/>

    <!-- Splash screen subtitle text -->
    <SolidColorBrush x:Key="SplashSubtitleForeground"
                     Color="#0D62B5"/>

    <!-- Splash screen progress bar track -->
    <SolidColorBrush x:Key="SplashProgressBackground"
                     Color="#E0E0E0"/>

    <!-- Splash screen status text -->
    <SolidColorBrush x:Key="SplashStatusForeground"
                     Color="#555555"/>

    <!-- Editor line number gutter text -->
    <SolidColorBrush x:Key="LineNumberForeground"
                     Color="#6E6E6E"/>

    <!-- Tab close/pin button default foreground -->
    <SolidColorBrush x:Key="TabButtonForeground"
                     Color="#999999"/>

    <!-- Tab close button hover foreground -->
    <SolidColorBrush x:Key="TabButtonHoverForeground"
                     Color="#1E1E1E"/>

    <!-- Pinned tab indicator color -->
    <SolidColorBrush x:Key="PinActiveColor"
                     Color="#FFC83D"/>

    <!-- XPath/JSONPath result line highlight (semi-transparent) -->
    <SolidColorBrush x:Key="ResultHighlightBrush"
                     Color="#50007ACC"/>

    <!-- Search panel match marker (semi-transparent orange) -->
    <SolidColorBrush x:Key="SearchMarkerBrush"
                     Color="#A0FFA500"/>

    <!-- Help window footer background -->
    <SolidColorBrush x:Key="HelpFooterBackground"
                     Color="#E8E8E8"/>

    <!-- Help window footer border -->
    <SolidColorBrush x:Key="HelpFooterBorder"
                     Color="#CCCCCC"/>

    <!-- Help window footer text -->
    <SolidColorBrush x:Key="HelpFooterForeground"
                     Color="#555555"/>

    <!-- Help window HTML body background -->
    <Color x:Key="HelpHtmlBackground">#F5F5F5</Color>
    <!-- Help window HTML body text -->
    <Color x:Key="HelpHtmlForeground">#1E1E1E</Color>
    <!-- Help window HTML h1 -->
    <Color x:Key="HelpHtmlH1">#111111</Color>
    <!-- Help window HTML h2 -->
    <Color x:Key="HelpHtmlH2">#1A7070</Color>
    <!-- Help window HTML h3 -->
    <Color x:Key="HelpHtmlH3">#0D62B5</Color>
    <!-- Help window HTML inline code text -->
    <Color x:Key="HelpHtmlCode">#6B5C00</Color>
    <!-- Help window HTML code/pre background -->
    <Color x:Key="HelpHtmlCodeBackground">#E8E8E8</Color>
    <!-- Help window HTML link color -->
    <Color x:Key="HelpHtmlLink">#0D62B5</Color>
    <!-- Help window HTML horizontal rule -->
    <Color x:Key="HelpHtmlHr">#DDDDDD</Color>
    <!-- Help window HTML table border -->
    <Color x:Key="HelpHtmlTableBorder">#CCCCCC</Color>
    <!-- Help window HTML table header background -->
    <Color x:Key="HelpHtmlTableHeader">#E8E8E8</Color>

    <!-- Tree view inactive selection background -->
    <SolidColorBrush x:Key="TreeItemInactiveSelected"
                     Color="#DAE8F5"/>

    <!-- Schema visualization colors -->
    <SolidColorBrush x:Key="SchemaComplexColor"
                     Color="#1A7070"/>
    <SolidColorBrush x:Key="SchemaSimpleColor"
                     Color="#0D62B5"/>
    <SolidColorBrush x:Key="SchemaSimpleBadge"
                     Color="#0D62B5"/>
    <SolidColorBrush x:Key="SchemaAttributeColor"
                     Color="#7A6800"/>
    <SolidColorBrush x:Key="SchemaRequiredBadge"
                     Color="#DC3545"/>
    <SolidColorBrush x:Key="SchemaOptionalBadge"
                     Color="#28A745"/>
    <SolidColorBrush x:Key="SchemaChoiceBadge"
                     Color="#FD7E14"/>
    <SolidColorBrush x:Key="SchemaRecursiveBadge"
                     Color="#6C757D"/>
    <SolidColorBrush x:Key="SchemaTypeLabelColor"
                     Color="#6A6A6A"/>
    <SolidColorBrush x:Key="SchemaDocColor"
                     Color="#3A7A1E"/>
    <SolidColorBrush x:Key="SchemaRestrictionColor"
                     Color="#A84300"/>
    <SolidColorBrush x:Key="SchemaTreeNodeBorder"
                     Color="#CCCCCC"/>
    <SolidColorBrush x:Key="SchemaTreeNodeBackground"
                     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SchemaTreeConnectorLine"
                     Color="#BBBBBB"/>

</ResourceDictionary>
