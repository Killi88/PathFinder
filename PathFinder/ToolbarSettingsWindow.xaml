<Window x:Class="PathFinder.ToolbarSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customize Toolbar"
        Width="700"
        Height="480"
        MinWidth="550"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource AppBackground}">

    <Window.Resources>
        <Style x:Key="DisableableButton"
                TargetType="Button">
            <Setter Property="Background"
                    Value="{DynamicResource ActionButtonBackground}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="{DynamicResource ActionButtonDisabled}"/>
                    <Setter Property="Foreground"
                            Value="{DynamicResource ActionButtonDisabledForeground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="16,12,16,8"
                BorderBrush="{DynamicResource GridSplitterColor}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="Add, remove, and reorder toolbar buttons"
                       Foreground="{DynamicResource LabelForeground}"
                       FontSize="12"/>
        </Border>

        <!-- Content: two lists with controls -->
        <Grid Grid.Row="1"
              Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Current Toolbar -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Current Toolbar"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource LabelForeground}"/>
                <ListBox x:Name="currentList"
                         Grid.Row="1"
                         Background="{DynamicResource EditorBackground}"
                         Foreground="{DynamicResource EditorForeground}"
                         BorderBrush="{DynamicResource SeparatorColor}"
                         BorderThickness="1"
                         SelectionChanged="CurrentList_SelectionChanged"/>
            </Grid>

            <!-- Center: action buttons -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="10,0">
                <Button x:Name="moveUpButton"
                        Content="▲"
                        ToolTip="Move Up"
                        Click="MoveUp_Click"
                        Padding="10,5"
                        Margin="0,2"
                        IsEnabled="False"
                        Style="{StaticResource DisableableButton}"/>
                <Button x:Name="moveDownButton"
                        Content="▼"
                        ToolTip="Move Down"
                        Click="MoveDown_Click"
                        Padding="10,5"
                        Margin="0,2"
                        IsEnabled="False"
                        Style="{StaticResource DisableableButton}"/>
                <Button x:Name="removeButton"
                        Content="✕ Remove"
                        ToolTip="Remove from toolbar"
                        Click="Remove_Click"
                        Padding="10,5"
                        Margin="0,8,0,2"
                        IsEnabled="False"
                        Style="{StaticResource DisableableButton}"/>
                <Button x:Name="addButton"
                        Content="← Add"
                        ToolTip="Add to toolbar"
                        Click="Add_Click"
                        Padding="10,5"
                        Margin="0,2"
                        IsEnabled="False"
                        Style="{StaticResource DisableableButton}"/>
                <Button Content="+ Separator"
                        ToolTip="Add a separator"
                        Click="AddSeparator_Click"
                        Padding="10,5"
                        Margin="0,8,0,2"
                        Cursor="Hand"
                        Background="{DynamicResource ActionButtonBackground}"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>

            <!-- Right: Available Buttons -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Available Buttons"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource LabelForeground}"/>
                <ListBox x:Name="availableList"
                         Grid.Row="1"
                         Background="{DynamicResource EditorBackground}"
                         Foreground="{DynamicResource EditorForeground}"
                         BorderBrush="{DynamicResource SeparatorColor}"
                         BorderThickness="1"
                         SelectionChanged="AvailableList_SelectionChanged"/>
            </Grid>
        </Grid>

        <!-- Button bar -->
        <Border Grid.Row="2"
                Padding="16,10"
                BorderBrush="{DynamicResource GridSplitterColor}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Button Content="Reset to Defaults"
                        HorizontalAlignment="Left"
                        Click="ResetDefaults_Click"
                        Padding="12,5"
                        Cursor="Hand"
                        Background="{DynamicResource ActionButtonBackground}"
                        Foreground="White"
                        BorderThickness="0"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="OK"
                            Click="OK_Click"
                            IsDefault="True"
                            Padding="20,5"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Background="{DynamicResource AccentBlue}"
                            Foreground="White"
                            BorderThickness="0"/>
                    <Button Content="Cancel"
                            Click="Cancel_Click"
                            IsCancel="True"
                            Padding="20,5"
                            Cursor="Hand"
                            Background="{DynamicResource ActionButtonBackground}"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
