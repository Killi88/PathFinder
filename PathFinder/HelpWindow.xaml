<Window x:Class="PathFinder.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PathFinder — Help"
        Height="760"
        Width="860"
        MinHeight="480"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        KeyDown="Window_KeyDown">

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WebBrowser x:Name="helpBrowser"
                            Grid.Row="0"/>

                <!-- ── Footer ── -->
                <Border x:Name="footerBorder"
                        Grid.Row="1"
                        Padding="24,10">
                        <Grid>
                                <TextBlock x:Name="footerText"
                                           Text="PathFinder  ·  .NET 8 / WPF  ·  AvalonEdit  ·  Newtonsoft.Json"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                                <Button Content="Close"
                                        HorizontalAlignment="Right"
                                        Click="Close_Click"
                                        Width="80"
                                        Height="28"
                                        Background="{DynamicResource ActionButtonBackground}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                        <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="2"
                                                                Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                        <Setter TargetName="bd"
                                                                                Property="Background"
                                                                                Value="{DynamicResource ActionButtonHover}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed"
                                                                         Value="True">
                                                                        <Setter TargetName="bd"
                                                                                Property="Background"
                                                                                Value="{DynamicResource ActionButtonPressed}"/>
                                                                </Trigger>
                                                        </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                        </Button.Template>
                                </Button>
                        </Grid>
                </Border>

        </Grid>
</Window>
